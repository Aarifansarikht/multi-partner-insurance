# Razorpay test/sandbox key (publishable key id only — never the secret).
# Get one from https://dashboard.razorpay.com (Test Mode -> Settings -> API Keys).
# Copy this file to `.env` and fill in your test key:
#   cp .env.example .env
#
# The app runs without a real key (it falls back to a simulated checkout), but
# to exercise the genuine Razorpay test widget, provide your own:
VITE_RAZORPAY_KEY_ID=rzp_test_T4ii3FhjcaWmmt
